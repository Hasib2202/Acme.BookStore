    "CorsOrigins": "https://*.BookStore.com,http://localhost:4200,https://localhost:44342,https://localhost:44308,https://localhost:44321,",
    "RedirectAllowedUrls": "http://localhost:4200,https://localhost:44361,https://localhost:44342,https://localhost:44354,https://localhost:44308,",
